{
  "functions": {
    "app/api/internal/scan-worker/route.ts": {
      "maxDuration": 300
    },
    "app/api/internal/sync-worker/route.ts": {
      "maxDuration": 300
    },
    "app/api/internal/cleanup/route.ts": {
      "maxDuration": 30
    },
    "app/api/internal/sync-schedule/route.ts": {
      "maxDuration": 60
    },
    "app/api/internal/threat-worker/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/internal/cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/internal/sync-worker",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/internal/threat-worker",
      "schedule": "*/15 * * * *"
    }
  ]
}
